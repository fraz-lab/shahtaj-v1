<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">

        <record id="rule_shahtaj_shop_booker_own" model="ir.rule">
            <field name="name">Order Booker: own shop registrations</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="domain_force">[
                '|',
                ('is_shahtaj_shop', '=', False),
                '|',
                ('registered_by_id', '=', user.id),
                ('route_id.weekly_schedule_ids.order_booker_id', '=', user.id),
            ]</field>
            <field name="groups" eval="[(4, ref('group_shahtaj_order_booker'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_shahtaj_visit_task_booker_own" model="ir.rule">
            <field name="name">Order Booker: own visit tasks</field>
            <field name="model_id" ref="model_shahtaj_visit_task"/>
            <field name="domain_force">[('order_booker_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_shahtaj_order_booker'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

