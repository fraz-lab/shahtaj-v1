<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shahtaj_generate_tasks_wizard_form" model="ir.ui.view">
        <field name="name">shahtaj.generate.tasks.wizard.form</field>
        <field name="model">shahtaj.generate.tasks.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Visit Tasks">
                <group>
                    <group>
                        <field name="date_from" required="1"/>
                        <field name="date_to" required="1"/>
                    </group>
                    <group>
                        <field name="order_booker_id"
                               placeholder="All bookers with schedules"/>
                    </group>
                </group>
                <footer>
                    <button name="action_generate" type="object"
                            string="Generate Tasks" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_shahtaj_generate_tasks_wizard" model="ir.actions.act_window">
        <field name="name">Generate Visit Tasks</field>
        <field name="res_model">shahtaj.generate.tasks.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
