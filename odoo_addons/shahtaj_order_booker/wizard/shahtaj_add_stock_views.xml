<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shahtaj_add_stock_form" model="ir.ui.view">
        <field name="name">shahtaj.add.stock.wizard.form</field>
        <field name="model">shahtaj.add.stock.wizard</field>
        <field name="arch" type="xml">
            <form string="Add Stock">
                <group>
                    <field name="product_id"/>
                    <field name="qty_on_hand"/>
                    <field name="qty_to_add"/>
                </group>
                <footer>
                    <button name="action_add_stock" type="object"
                            string="Add Stock" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_shahtaj_add_stock" model="ir.actions.act_window">
        <field name="name">Add Stock</field>
        <field name="res_model">shahtaj.add.stock.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
