<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Applied on every module upgrade (noupdate=0, loaded last in __manifest__.py).
        Replaces scattered partner_access_*_fix.xml files that failed to update
        databases where shahtaj_partner_access.xml was installed with noupdate=1.
    -->
    <data noupdate="0">
        <delete model="ir.rule" id="rule_shahtaj_distributor_shops"/>

        <record id="rule_shahtaj_distributor_partner_read" model="ir.rule">
            <field name="name">Distributor: read shops and staff contacts</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="domain_force">[
                '|', '|', '|', '|', '|', '|',
                ('is_shahtaj_shop', '=', True),
                ('parent_id.is_shahtaj_shop', '=', True),
                ('commercial_partner_id.is_shahtaj_shop', '=', True),
                ('partner_share', '=', False),
                ('id', '=', user.partner_id.id),
                ('id', '=', user.company_id.partner_id.id),
                ('customer_rank', '>', 0),
            ]</field>
            <field name="groups" eval="[(4, ref('group_shahtaj_distributor'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>
