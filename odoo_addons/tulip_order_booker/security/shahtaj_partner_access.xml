<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">

        <!-- Distributor: read shops, internal user contacts (bookers), and own contact -->
        <record id="rule_shahtaj_distributor_partner_read" model="ir.rule">
            <field name="name">Distributor: read shops and staff contacts</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="domain_force">[
                '|', '|',
                ('is_shahtaj_shop', '=', True),
                ('partner_share', '=', False),
                ('id', '=', user.partner_id.id),
            ]</field>
            <field name="groups" eval="[(4, ref('group_shahtaj_distributor'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Distributor: create and update Shahtaj shops only -->
        <record id="rule_shahtaj_distributor_shops" model="ir.rule">
            <field name="name">Distributor: manage Shahtaj shops</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="domain_force">[('is_shahtaj_shop', '=', True)]</field>
            <field name="groups" eval="[(4, ref('group_shahtaj_distributor'))]"/>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>

</odoo>
