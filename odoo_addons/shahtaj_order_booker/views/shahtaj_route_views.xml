<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shahtaj_route_list" model="ir.ui.view">
        <field name="name">shahtaj.route.list</field>
        <field name="model">shahtaj.route</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="zone_id"/>
                <field name="shop_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_shahtaj_route_form" model="ir.ui.view">
        <field name="name">shahtaj.route.form</field>
        <field name="model">shahtaj.route</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button string="Save" special="save" class="oe_highlight" data-hotkey="s"/>
                    <button string="Discard" special="cancel" data-hotkey="j"/>
                </header>
                <sheet>
                    <div class="alert alert-info" role="alert">
                        <strong>Setup order:</strong>
                        1) Pick a zone → 2) Add shops below.
                        Assign order bookers to this route under <b>Weekly Schedules</b>.
                    </div>
                    <div class="oe_title">
                        <label for="name" string="Route Name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Route A" required="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Zone">
                            <field name="zone_id" required="1" options="{'no_create': False}"/>
                        </group>
                        <group string="Status">
                            <field name="shop_count"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Shops on this route" name="shops">
                            <field name="shop_ids"
                                   context="{
                                       'shahtaj_shop_form': True,
                                       'default_is_shahtaj_shop': True,
                                       'default_shop_approval_state': 'approved',
                                       'default_company_type': 'company',
                                       'default_route_id': id,
                                       'default_zone_id': zone_id,
                                       'form_view_ref': 'shahtaj_order_booker.view_shahtaj_shop_form'
                                   }">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="owner_name"/>
                                    <field name="owner_phone"/>
                                    <field name="route_id" column_invisible="1"/>
                                    <field name="zone_id" column_invisible="1"/>
                                    <field name="shop_approval_state" widget="badge"
                                           decoration-success="shop_approval_state == 'approved'"
                                           decoration-warning="shop_approval_state == 'pending'"/>
                                    <field name="partner_latitude"/>
                                    <field name="partner_longitude"/>
                                </list>
                            </field>
                            <p class="text-muted">
                                Click <b>Add a line</b> to pick an existing shop, or <b>Create</b> to register a new one.
                            </p>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button string="Save" special="save" class="btn-primary" data-hotkey="s"/>
                    <button string="Discard" special="cancel" class="btn-secondary" data-hotkey="j"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_shahtaj_route" model="ir.actions.act_window">
        <field name="name">Routes</field>
        <field name="res_model">shahtaj.route</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a sales route
            </p>
            <p>
                Each route belongs to one zone and lists the shops visited on that route.
                Order bookers are assigned per weekday under Weekly Schedules.
            </p>
        </field>
    </record>

    <record id="action_shahtaj_route_by_zone" model="ir.actions.act_window">
        <field name="name">Routes</field>
        <field name="res_model">shahtaj.route</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('zone_id', '=', active_id)]</field>
        <field name="context">{'default_zone_id': active_id}</field>
    </record>

</odoo>
