<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shahtaj_order_booker_list" model="ir.ui.view">
        <field name="name">res.users.list.shahtaj.order.booker</field>
        <field name="model">res.users</field>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <list decoration-muted="not active">
                <field name="name"/>
                <field name="login"/>
                <field name="shahtaj_employee_code" optional="show"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="shahtaj_online_status" widget="badge"
                       decoration-success="shahtaj_online_status == 'online'"
                       decoration-warning="shahtaj_online_status == 'away'"
                       decoration-muted="shahtaj_online_status == 'offline'"/>
                <field name="shahtaj_last_seen_at" optional="show"/>
                <field name="shahtaj_task_today_total" string="Tasks Today"/>
                <field name="shahtaj_task_today_pending" string="Pending"/>
                <field name="shahtaj_task_today_done" string="Done"/>
                <field name="shahtaj_schedule_count" string="Schedules"/>
                <field name="shahtaj_active_target_progress" string="Target %" widget="progressbar"/>
                <field name="shahtaj_active_target_summary" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_shahtaj_order_booker_form" model="ir.ui.view">
        <field name="name">res.users.form.shahtaj.order.booker</field>
        <field name="model">res.users</field>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <form string="Order Booker">
                <header>
                    <button name="action_shahtaj_activate_booker" type="object"
                            string="Activate" class="oe_highlight"
                            invisible="active"/>
                    <button name="action_shahtaj_deactivate_booker" type="object"
                            string="Deactivate"
                            invisible="not active"
                            confirm="Deactivate this order booker? They will not be able to log in."/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_shahtaj_open_visit_hub" type="object"
                                class="oe_stat_button" icon="fa-calendar-check-o">
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field name="shahtaj_task_today_pending"/> /
                                    <field name="shahtaj_task_today_total"/>
                                </span>
                                <span class="o_stat_text">Tasks Today</span>
                            </div>
                        </button>
                        <button name="action_shahtaj_manage_schedules" type="object"
                                class="oe_stat_button" icon="fa-calendar">
                            <field name="shahtaj_schedule_count" widget="statinfo" string="Schedules"/>
                        </button>
                        <button name="action_shahtaj_view_targets" type="object"
                                class="oe_stat_button" icon="fa-bullseye">
                            <field name="shahtaj_target_count" widget="statinfo" string="Targets"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <group>
                        <group string="Account">
                            <field name="name" readonly="1"/>
                            <field name="login" readonly="1"/>
                            <field name="shahtaj_employee_code"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group string="Field Status">
                            <field name="shahtaj_online_status" widget="badge"
                                   decoration-success="shahtaj_online_status == 'online'"
                                   decoration-warning="shahtaj_online_status == 'away'"
                                   decoration-muted="shahtaj_online_status == 'offline'"/>
                            <field name="shahtaj_last_seen_at"/>
                            <field name="shahtaj_im_status" invisible="1"/>
                        </group>
                    </group>
                    <group string="Today's Progress">
                        <group>
                            <field name="shahtaj_task_today_total" readonly="1"/>
                            <field name="shahtaj_task_today_pending" readonly="1"/>
                            <field name="shahtaj_task_today_done" readonly="1"/>
                        </group>
                        <group>
                            <field name="shahtaj_active_target_progress" widget="progressbar" readonly="1"/>
                            <field name="shahtaj_active_target_summary" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Weekly Schedules" name="schedules">
                            <field name="shahtaj_schedule_ids" readonly="1">
                                <list>
                                    <field name="day_of_week"/>
                                    <field name="route_id"/>
                                    <field name="zone_id"/>
                                    <field name="shop_count"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                        <page string="Targets" name="targets">
                            <field name="shahtaj_target_ids" readonly="1">
                                <list>
                                    <field name="date_start"/>
                                    <field name="date_end"/>
                                    <field name="target_type"/>
                                    <field name="target_value"/>
                                    <field name="achieved_value"/>
                                    <field name="progress_percent" widget="progressbar"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <field name="shahtaj_is_order_booker" invisible="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_shahtaj_order_booker_search" model="ir.ui.view">
        <field name="name">res.users.search.shahtaj.order.booker</field>
        <field name="model">res.users</field>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="login"/>
                <field name="shahtaj_employee_code"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <filter string="Online" name="online"
                        domain="[('shahtaj_online_status', '=', 'online')]"/>
                <filter string="Offline" name="offline"
                        domain="[('shahtaj_online_status', '=', 'offline')]"/>
            </search>
        </field>
    </record>

    <record id="action_shahtaj_order_booker_management" model="ir.actions.act_window">
        <field name="name">Order Bookers</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('shahtaj_is_order_booker', '=', True)]</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="search_view_id" ref="view_shahtaj_order_booker_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first order booker
            </p>
            <p>
                Manage field staff logins, online status, schedules, tasks, and targets.
            </p>
        </field>
    </record>

    <record id="action_shahtaj_order_booker_management_view_list" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_shahtaj_order_booker_list"/>
        <field name="act_window_id" ref="action_shahtaj_order_booker_management"/>
    </record>

    <record id="action_shahtaj_order_booker_management_view_form" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_shahtaj_order_booker_form"/>
        <field name="act_window_id" ref="action_shahtaj_order_booker_management"/>
    </record>

</odoo>
