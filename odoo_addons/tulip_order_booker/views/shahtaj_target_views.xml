<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shahtaj_visit_target_list" model="ir.ui.view">
        <field name="name">shahtaj.visit.target.list</field>
        <field name="model">shahtaj.visit.target</field>
        <field name="arch" type="xml">
            <list>
                <field name="order_booker_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="target_type"/>
                <field name="target_value"/>
                <field name="achieved_value"/>
                <field name="progress_percent" widget="progressbar"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_shahtaj_visit_target_form" model="ir.ui.view">
        <field name="name">shahtaj.visit.target.form</field>
        <field name="model">shahtaj.visit.target</field>
        <field name="arch" type="xml">
            <form string="Order Booker Target">
                <header>
                    <button string="Save" special="save" class="oe_highlight" data-hotkey="s"/>
                    <button string="Discard" special="cancel" data-hotkey="j"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="order_booker_id" required="1"/>
                            <field name="date_start" required="1"/>
                            <field name="date_end" required="1"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="target_type" required="1"/>
                            <field name="target_value" required="1"/>
                            <field name="product_id"
                                   invisible="target_type != 'product_qty'"
                                   required="target_type == 'product_qty'"/>
                            <field name="currency_id" invisible="target_type != 'sales_amount'"/>
                        </group>
                    </group>
                    <group string="Progress">
                        <group>
                            <field name="achieved_value" readonly="1"/>
                            <field name="progress_percent" widget="progressbar" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Save" special="save" class="btn-primary" data-hotkey="s"/>
                    <button string="Discard" special="cancel" class="btn-secondary" data-hotkey="j"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_shahtaj_visit_target" model="ir.actions.act_window">
        <field name="name">Order Booker Targets</field>
        <field name="res_model">shahtaj.visit.target</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Set a target for an order booker
            </p>
            <p>
                Examples: monthly sales amount, visit count, or product quantity to book.
                Progress updates from completed tasks and sale orders.
            </p>
        </field>
    </record>

    <record id="action_shahtaj_visit_target_my" model="ir.actions.act_window">
        <field name="name">My Targets</field>
        <field name="res_model">shahtaj.visit.target</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('order_booker_id', '=', uid), ('active', '=', True)]</field>
        <field name="context">{'create': False, 'edit': False}</field>
    </record>

</odoo>
