<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Shared shop list -->
    <record id="view_shahtaj_shop_list" model="ir.ui.view">
        <field name="name">res.partner.list.shahtaj.shop</field>
        <field name="model">res.partner</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" string="Shop Name"/>
                <field name="owner_name"/>
                <field name="owner_phone"/>
                <field name="shop_approval_state" widget="badge"
                       decoration-success="shop_approval_state == 'approved'"
                       decoration-warning="shop_approval_state == 'pending'"
                       decoration-danger="shop_approval_state == 'rejected'"/>
                <field name="zone_id" optional="show"/>
                <field name="route_id" optional="show"/>
                <field name="partner_latitude" string="Latitude"/>
                <field name="partner_longitude" string="Longitude"/>
                <field name="credit_limit" optional="hide"/>
                <field name="legacy_balance" optional="hide"/>
                <field name="outstanding_balance" optional="show"/>
                <field name="registered_by_id" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Distributor / back-office shop form -->
    <record id="view_shahtaj_shop_form" model="ir.ui.view">
        <field name="name">res.partner.form.shahtaj.shop</field>
        <field name="model">res.partner</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <form string="Shop">
                <header>
                    <button string="Save" special="save" class="oe_highlight" data-hotkey="s"/>
                    <button string="Discard" special="cancel" data-hotkey="j"/>
                    <button name="action_approve_shop" type="object" string="Approve Shop"
                            class="oe_highlight"
                            invisible="shop_approval_state == 'approved'"/>
                    <button name="action_reject_shop" type="object" string="Reject"
                            invisible="shop_approval_state == 'rejected'"/>
                    <button name="action_view_legacy_balance_move" type="object"
                            string="Legacy Balance Entry"
                            invisible="not legacy_balance_move_id"
                            groups="shahtaj_order_booker.group_shahtaj_distributor,account.group_account_readonly,account.group_account_invoice"/>
                    <field name="shop_approval_state" widget="statusbar"
                           statusbar_visible="pending,approved,rejected"/>
                </header>
                <sheet>
                    <field name="company_type" invisible="1"/>
                    <field name="is_shahtaj_shop" invisible="1"/>
                    <field name="type" invisible="1"/>
                    <field name="allowed_zone_ids" invisible="1"/>
                    <field name="allowed_route_ids" invisible="1"/>
                    <field name="legacy_balance_move_id" invisible="1"/>
                    <field name="currency_id" invisible="1"/>
                    <field name="sale_order_count" invisible="1"/>
                    <field name="account_move_count" invisible="1"/>
                    <field name="credit" invisible="1"/>
                    <div class="oe_button_box" name="button_box">
                        <button type="object"
                                name="action_shahtaj_view_sale_orders"
                                class="oe_stat_button"
                                icon="fa-shopping-cart"
                                groups="shahtaj_order_booker.group_shahtaj_distributor">
                            <field name="sale_order_count" widget="statinfo" string="Sales Orders"/>
                        </button>
                        <button type="object"
                                name="action_view_partner_invoices"
                                class="oe_stat_button"
                                icon="fa-pencil-square-o"
                                groups="shahtaj_order_booker.group_shahtaj_distributor">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="total_invoiced" widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                </span>
                                <span class="o_stat_text">Invoiced</span>
                            </div>
                        </button>
                        <button type="object"
                                name="action_shahtaj_view_customer_payments"
                                class="oe_stat_button"
                                icon="fa-money"
                                groups="shahtaj_order_booker.group_shahtaj_distributor">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="outstanding_balance" widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                </span>
                                <span class="o_stat_text">Outstanding</span>
                            </div>
                        </button>
                        <button type="object"
                                name="action_shahtaj_view_receivable_entries"
                                class="oe_stat_button"
                                icon="fa-book"
                                groups="shahtaj_order_booker.group_shahtaj_distributor">
                            <span class="o_stat_text">Receivable Lines</span>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" string="Shop Name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Ali General Store" required="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Owner">
                            <field name="owner_name" required="1"/>
                            <field name="owner_phone" required="1" widget="phone"/>
                        </group>
                        <group string="Assignment">
                            <field name="zone_id" options="{'no_create': True}"/>
                            <field name="route_id"
                                   domain="[('id', 'in', allowed_route_ids)]"
                                   invisible="not zone_id"
                                   options="{'no_create': True}"/>
                            <field name="registered_by_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="GPS Location">
                        <group>
                            <field name="partner_latitude" string="GPS Latitude" required="1"/>
                            <field name="partner_longitude" string="GPS Longitude" required="1"/>
                        </group>
                        <group>
                            <div class="text-muted">
                                Shop GPS is used to validate visits (order booker must be within 100 m).
                            </div>
                        </group>
                    </group>
                    <group string="Credit and Balance">
                        <group>
                            <field name="use_partner_credit_limit"/>
                            <field name="credit_limit" string="Credit Limit (Rs)"
                                   invisible="not use_partner_credit_limit"/>
                            <field name="legacy_balance" string="Legacy Balance (Rs)"
                                   readonly="legacy_balance_move_id"/>
                            <field name="property_payment_term_id"
                                   string="Payment Terms"
                                   options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="outstanding_balance" string="Outstanding Balance (Rs)"/>
                            <field name="credit" string="Total Receivable (Odoo)"
                                   groups="account.group_account_invoice,account.group_account_readonly"/>
                            <field name="property_account_receivable_id"
                                   string="Receivable Account"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group string="Verification Photos">
                        <group>
                            <field name="owner_cnic_front" widget="image" class="oe_avatar"/>
                            <field name="owner_cnic_back" widget="image" class="oe_avatar"/>
                        </group>
                        <group>
                            <field name="owner_photo" widget="image" class="oe_avatar"/>
                            <field name="shop_exterior_photo" widget="image" class="oe_avatar"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Save" special="save" class="btn-primary" data-hotkey="s"/>
                    <button string="Discard" special="cancel" class="btn-secondary" data-hotkey="j"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Order booker: shops they registered -->
    <record id="view_shahtaj_shop_register_list_booker" model="ir.ui.view">
        <field name="name">res.partner.list.shahtaj.shop.register.booker</field>
        <field name="model">res.partner</field>
        <field name="priority">5</field>
        <field name="arch" type="xml">
            <list string="My Registered Shops" create="1" edit="0" delete="0">
                <field name="name" string="Shop Name"/>
                <field name="owner_name"/>
                <field name="owner_phone"/>
                <field name="shop_approval_state" widget="badge"
                       decoration-success="shop_approval_state == 'approved'"
                       decoration-warning="shop_approval_state == 'pending'"
                       decoration-danger="shop_approval_state == 'rejected'"/>
                <field name="zone_id" optional="show"/>
                <field name="route_id" optional="show"/>
                <field name="create_date" string="Registered On" optional="show"/>
            </list>
        </field>
    </record>

    <!-- Order booker registration form (same fields, no approval controls) -->
    <record id="view_shahtaj_shop_register_form" model="ir.ui.view">
        <field name="name">res.partner.form.shahtaj.shop.register</field>
        <field name="model">res.partner</field>
        <field name="priority">2</field>
        <field name="arch" type="xml">
            <form string="Register New Shop">
                <header>
                    <button string="Register Shop" special="save" class="oe_highlight" data-hotkey="s"
                            invisible="id and shop_approval_state in ('approved', 'rejected')"/>
                    <button string="Discard" special="cancel" data-hotkey="j"/>
                    <field name="shop_approval_state" widget="statusbar"
                           statusbar_visible="pending,approved,rejected"
                           invisible="not id"/>
                </header>
                <sheet>
                    <field name="company_type" invisible="1"/>
                    <field name="is_shahtaj_shop" invisible="1"/>
                    <field name="type" invisible="1"/>
                    <field name="allowed_zone_ids" invisible="1"/>
                    <field name="allowed_route_ids" invisible="1"/>
                    <field name="legacy_balance_move_id" invisible="1"/>
                    <field name="currency_id" invisible="1"/>
                    <field name="registered_by_id" invisible="1"/>
                    <div class="alert alert-info" role="alert" invisible="id">
                        Submit shop details for distributor approval.
                        Select a zone, then choose a route in that zone.
                    </div>
                    <div class="alert alert-warning" role="alert"
                         invisible="shop_approval_state != 'pending' or not id">
                        Waiting for distributor approval. You can still edit this registration while pending.
                    </div>
                    <div class="alert alert-success" role="alert"
                         invisible="shop_approval_state != 'approved'">
                        This shop has been approved. Visit tasks will appear on your schedule.
                    </div>
                    <div class="alert alert-danger" role="alert"
                         invisible="shop_approval_state != 'rejected'">
                        This registration was rejected. Contact your distributor for details.
                    </div>
                    <div class="oe_title">
                        <label for="name" string="Shop Name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Ali General Store" required="1"
                                   readonly="shop_approval_state in ('approved', 'rejected')"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="owner_name" required="1" placeholder="Owner full name"
                                   readonly="shop_approval_state in ('approved', 'rejected')"/>
                            <field name="owner_phone" required="1" widget="phone"
                                   placeholder="03xx xxxxxxx"
                                   readonly="shop_approval_state in ('approved', 'rejected')"/>
                        </group>
                        <group>
                            <field name="zone_id"
                                   string="Zone (Optional)"
                                   options="{'no_create': True}"
                                   readonly="shop_approval_state in ('approved', 'rejected')"/>
                            <field name="route_id"
                                   string="Route (Optional)"
                                   domain="[('id', 'in', allowed_route_ids)]"
                                   invisible="not zone_id"
                                   options="{'no_create': True}"
                                   readonly="shop_approval_state in ('approved', 'rejected')"/>
                        </group>
                    </group>
                    <group string="Shop GPS">
                        <group>
                            <field name="partner_latitude" string="GPS Latitude" required="1"
                                   placeholder="e.g. 31.5204"
                                   readonly="shop_approval_state in ('approved', 'rejected')"/>
                            <field name="partner_longitude" string="GPS Longitude" required="1"
                                   placeholder="e.g. 74.3587"
                                   readonly="shop_approval_state in ('approved', 'rejected')"/>
                        </group>
                    </group>
                    <group string="Credit and Balance (Optional)"
                           invisible="shop_approval_state in ('approved', 'rejected')">
                        <group>
                            <field name="credit_limit" string="Credit Limit (Rs)"
                                   placeholder="Optional"/>
                            <field name="legacy_balance" string="Legacy Balance (Rs)"
                                   placeholder="Optional"/>
                        </group>
                    </group>
                    <group string="Photos (Optional)">
                        <group>
                            <field name="owner_cnic_front" widget="image" class="oe_avatar"
                                   readonly="shop_approval_state in ('approved', 'rejected')"/>
                            <field name="owner_cnic_back" widget="image" class="oe_avatar"
                                   readonly="shop_approval_state in ('approved', 'rejected')"/>
                        </group>
                        <group>
                            <field name="owner_photo" widget="image" class="oe_avatar"
                                   readonly="shop_approval_state in ('approved', 'rejected')"/>
                            <field name="shop_exterior_photo" widget="image" class="oe_avatar"
                                   readonly="shop_approval_state in ('approved', 'rejected')"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Register Shop" special="save" class="btn-primary" data-hotkey="s"/>
                    <button string="Discard" special="cancel" class="btn-secondary" data-hotkey="j"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Distributor: manage all shops (auto-approved) -->
    <record id="action_shahtaj_shop" model="ir.actions.act_window">
        <field name="name">Shops</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_shahtaj_shop', '=', True)]</field>
        <field name="context">{
            'shahtaj_shop_form': True,
            'default_is_shahtaj_shop': True,
            'default_shop_approval_state': 'approved',
            'default_company_type': 'company'
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first retail shop
            </p>
            <p>
                Add shop name, owner details, GPS, credit limit, and legacy balance.
                Legacy balance is posted to accounting when the shop is approved.
            </p>
        </field>
    </record>

    <record id="action_shahtaj_shop_view_list" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_shahtaj_shop_list"/>
        <field name="act_window_id" ref="action_shahtaj_shop"/>
    </record>

    <record id="action_shahtaj_shop_view_form" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_shahtaj_shop_form"/>
        <field name="act_window_id" ref="action_shahtaj_shop"/>
    </record>

    <!-- Order booker: list of own shop registrations -->
    <record id="action_shahtaj_shop_register" model="ir.actions.act_window">
        <field name="name">My Registered Shops</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('is_shahtaj_shop', '=', True),
            ('registered_by_id', '=', uid),
        ]</field>
        <field name="context">{
            'shahtaj_shop_form': True,
            'shahtaj_shop_register': True,
            'default_is_shahtaj_shop': True,
            'default_shop_approval_state': 'pending',
            'default_company_type': 'company',
            'default_registered_by_id': uid,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No shops registered yet
            </p>
            <p>
                Click <b>New</b> to register a shop for distributor approval.
                Your registrations appear here with pending, approved, or rejected status.
            </p>
        </field>
    </record>

    <record id="action_shahtaj_shop_register_view_list" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_shahtaj_shop_register_list_booker"/>
        <field name="act_window_id" ref="action_shahtaj_shop_register"/>
    </record>

    <record id="action_shahtaj_shop_register_view_form" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_shahtaj_shop_register_form"/>
        <field name="act_window_id" ref="action_shahtaj_shop_register"/>
    </record>

    <!-- Pending approvals (distributor) -->
    <record id="action_shahtaj_shop_pending" model="ir.actions.act_window">
        <field name="name">Pending Shop Approvals</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_shahtaj_shop', '=', True), ('shop_approval_state', '=', 'pending')]</field>
        <field name="context">{
            'shahtaj_shop_form': True,
            'default_is_shahtaj_shop': True,
            'default_company_type': 'company'
        }</field>
    </record>

    <record id="action_shahtaj_shop_pending_view_list" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_shahtaj_shop_list"/>
        <field name="act_window_id" ref="action_shahtaj_shop_pending"/>
    </record>

    <record id="action_shahtaj_shop_pending_view_form" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_shahtaj_shop_form"/>
        <field name="act_window_id" ref="action_shahtaj_shop_pending"/>
    </record>

</odoo>
