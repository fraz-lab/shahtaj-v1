<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shahtaj_weekly_schedule_list" model="ir.ui.view">
        <field name="name">shahtaj.weekly.schedule.list</field>
        <field name="model">shahtaj.weekly.schedule</field>
        <field name="arch" type="xml">
            <list>
                <field name="order_booker_id"/>
                <field name="day_of_week"/>
                <field name="route_id"/>
                <field name="zone_id"/>
                <field name="shop_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Distributor planner: edit routes directly on schedule model (not via res.users) -->
    <record id="view_shahtaj_weekly_schedule_list_planner" model="ir.ui.view">
        <field name="name">shahtaj.weekly.schedule.list.planner</field>
        <field name="model">shahtaj.weekly.schedule</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <list editable="bottom" default_order="day_of_week,route_id">
                <field name="order_booker_id" column_invisible="context.get('default_order_booker_id')"/>
                <field name="is_day_locked" column_invisible="1"/>
                <field name="day_of_week" readonly="is_day_locked"/>
                <field name="route_id" readonly="is_day_locked"
                       options="{'no_create': True}"/>
                <field name="zone_id"/>
                <field name="shop_count"/>
                <field name="week_occurrence_date" string="This Week" readonly="1"/>
                <field name="week_tasks_completed" string="Done" readonly="1"/>
                <field name="week_tasks_planned" string="Planned" readonly="1"/>
                <field name="week_tasks_progress" widget="progressbar" readonly="1"/>
                <field name="active" readonly="is_day_locked"/>
            </list>
        </field>
    </record>

    <record id="view_shahtaj_weekly_schedule_form" model="ir.ui.view">
        <field name="name">shahtaj.weekly.schedule.form</field>
        <field name="model">shahtaj.weekly.schedule</field>
        <field name="arch" type="xml">
            <form string="Weekly Schedule">
                <header>
                    <button string="Save" special="save" class="oe_highlight" data-hotkey="s"/>
                    <button string="Discard" special="cancel" data-hotkey="j"/>
                </header>
                <sheet>
                    <div class="alert alert-info" role="alert">
                        One line = one route on one weekday for one order booker.
                        Add <b>multiple lines</b> for the same day to assign multiple routes.
                    </div>
                    <group>
                        <group>
                            <field name="order_booker_id" required="1"/>
                            <field name="day_of_week" required="1"/>
                        </group>
                        <group>
                            <field name="route_id" required="1"/>
                            <field name="zone_id"/>
                            <field name="shop_count"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Save" special="save" class="btn-primary" data-hotkey="s"/>
                    <button string="Discard" special="cancel" class="btn-secondary" data-hotkey="j"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_shahtaj_weekly_schedule_form_planner" model="ir.ui.view">
        <field name="name">shahtaj.weekly.schedule.form.planner</field>
        <field name="model">shahtaj.weekly.schedule</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <form string="Schedule Line">
                <sheet>
                    <div class="alert alert-warning" role="alert" invisible="not is_day_locked">
                        This weekday is <b>today</b> — existing assignments cannot be changed
                        (visit statistics are in progress). Add a new line for another day instead.
                    </div>
                    <group>
                        <group>
                            <field name="is_day_locked" invisible="1"/>
                            <field name="order_booker_id" readonly="context.get('default_order_booker_id')"/>
                            <field name="day_of_week" readonly="is_day_locked"/>
                            <field name="route_id" readonly="is_day_locked"/>
                        </group>
                        <group>
                            <field name="zone_id"/>
                            <field name="shop_count"/>
                            <field name="week_occurrence_date" readonly="1"/>
                            <field name="week_tasks_completed" readonly="1"/>
                            <field name="week_tasks_planned" readonly="1"/>
                            <field name="active" readonly="is_day_locked"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_shahtaj_weekly_schedule_search" model="ir.ui.view">
        <field name="name">shahtaj.weekly.schedule.search</field>
        <field name="model">shahtaj.weekly.schedule</field>
        <field name="arch" type="xml">
            <search>
                <field name="order_booker_id"/>
                <field name="route_id"/>
                <field name="day_of_week"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Day of Week" name="group_day" context="{'group_by': 'day_of_week'}"/>
            </search>
        </field>
    </record>

    <record id="action_shahtaj_weekly_schedule" model="ir.actions.act_window">
        <field name="name">Weekly Schedules</field>
        <field name="res_model">shahtaj.weekly.schedule</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define weekly route plans
            </p>
            <p>
                Example: Ahmed — Monday — Route A, and another line Ahmed — Monday — Route C.
                Visit tasks are created automatically when schedules are saved.
            </p>
        </field>
    </record>

</odoo>
