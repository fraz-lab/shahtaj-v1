<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shahtaj_quick_add_product_form" model="ir.ui.view">
        <field name="name">shahtaj.quick.add.product.wizard.form</field>
        <field name="model">shahtaj.quick.add.product.wizard</field>
        <field name="arch" type="xml">
            <form string="Quick Add Product">
                <group>
                    <field name="name" placeholder="e.g. Cheese Burger"/>
                    <field name="list_price"/>
                    <field name="track_inventory"/>
                    <field name="opening_qty" invisible="not track_inventory"/>
                </group>
                <footer>
                    <button name="action_create_product" type="object"
                            string="Create Product" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_shahtaj_quick_add_product" model="ir.actions.act_window">
        <field name="name">Quick Add Product</field>
        <field name="res_model">shahtaj.quick.add.product.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
