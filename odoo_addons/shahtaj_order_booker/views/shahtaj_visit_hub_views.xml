<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shahtaj_visit_task_embedded_list" model="ir.ui.view">
        <field name="name">shahtaj.visit.task.list.embedded</field>
        <field name="model">shahtaj.visit.task</field>
        <field name="arch" type="xml">
            <list decoration-muted="state in ('cancelled', 'skipped')"
                  decoration-success="state == 'completed'"
                  decoration-warning="state == 'pending'"
                  decoration-info="state == 'in_progress'"
                  create="false" delete="false">
                <field name="scheduled_date" optional="show"/>
                <field name="route_id"/>
                <field name="zone_id" optional="hide"/>
                <field name="shop_id"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'completed'"
                       decoration-warning="state == 'pending'"
                       decoration-info="state == 'in_progress'"
                       decoration-danger="state in ('cancelled', 'skipped')"/>
            </list>
        </field>
    </record>

    <record id="view_shahtaj_visit_hub_list" model="ir.ui.view">
        <field name="name">res.users.list.shahtaj.visit.hub</field>
        <field name="model">res.users</field>
        <field name="priority">40</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="login" optional="show"/>
                <field name="shahtaj_employee_code" optional="show"/>
                <field name="shahtaj_task_today_done" string="Today Done"/>
                <field name="shahtaj_task_today_pending" string="Today Pending"/>
                <field name="shahtaj_task_today_total" string="Today Total"/>
                <field name="shahtaj_week_task_progress" string="Week %" widget="progressbar"/>
                <field name="shahtaj_week_task_done" string="Week Done"/>
                <field name="shahtaj_week_task_total" string="Week Total"/>
                <field name="shahtaj_online_status" widget="badge" optional="show"
                       decoration-success="shahtaj_online_status == 'online'"
                       decoration-warning="shahtaj_online_status == 'away'"
                       decoration-muted="shahtaj_online_status == 'offline'"/>
            </list>
        </field>
    </record>

    <record id="view_shahtaj_visit_hub_form" model="ir.ui.view">
        <field name="name">res.users.form.shahtaj.visit.hub</field>
        <field name="model">res.users</field>
        <field name="priority">40</field>
        <field name="arch" type="xml">
            <form string="Visit Tasks">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                        <div class="text-muted">
                            <field name="login" readonly="1"/> —
                            <field name="shahtaj_employee_code" readonly="1"/>
                        </div>
                    </div>
                    <group string="Progress Summary">
                        <group string="Today">
                            <field name="shahtaj_task_today_done" readonly="1"/>
                            <field name="shahtaj_task_today_pending" readonly="1"/>
                            <field name="shahtaj_task_today_total" readonly="1"/>
                        </group>
                        <group string="This Week">
                            <field name="shahtaj_week_task_progress" widget="progressbar" readonly="1"/>
                            <field name="shahtaj_week_task_done" readonly="1"/>
                            <field name="shahtaj_week_task_total" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Today" name="today">
                            <field name="shahtaj_task_today_ids" readonly="1" nolabel="1"
                                   context="{'list_view_ref': 'shahtaj_order_booker.view_shahtaj_visit_task_embedded_list'}">
                                <list decoration-muted="state in ('cancelled', 'skipped')"
                                      decoration-success="state == 'completed'"
                                      decoration-warning="state == 'pending'"
                                      decoration-info="state == 'in_progress'">
                                    <field name="route_id"/>
                                    <field name="shop_id"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'completed'"
                                           decoration-warning="state == 'pending'"
                                           decoration-info="state == 'in_progress'"/>
                                </list>
                            </field>
                        </page>
                        <page string="This Week" name="week">
                            <field name="shahtaj_task_week_ids" readonly="1" nolabel="1">
                                <list decoration-muted="state in ('cancelled', 'skipped')"
                                      decoration-success="state == 'completed'"
                                      decoration-warning="state == 'pending'"
                                      decoration-info="state == 'in_progress'"
                                      default_group_by="scheduled_date">
                                    <field name="scheduled_date"/>
                                    <field name="route_id"/>
                                    <field name="shop_id"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'completed'"
                                           decoration-warning="state == 'pending'"
                                           decoration-info="state == 'in_progress'"/>
                                </list>
                            </field>
                        </page>
                        <page string="History" name="history">
                            <field name="shahtaj_task_history_ids" readonly="1" nolabel="1">
                                <list decoration-muted="state in ('cancelled', 'skipped')"
                                      decoration-success="state == 'completed'"
                                      decoration-warning="state == 'pending'"
                                      decoration-info="state == 'in_progress'"
                                      default_group_by="scheduled_date">
                                    <field name="scheduled_date"/>
                                    <field name="route_id"/>
                                    <field name="shop_id"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'completed'"
                                           decoration-warning="state == 'pending'"
                                           decoration-info="state == 'in_progress'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <field name="shahtaj_is_order_booker" invisible="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_shahtaj_visit_hub_search" model="ir.ui.view">
        <field name="name">res.users.search.shahtaj.visit.hub</field>
        <field name="model">res.users</field>
        <field name="priority">40</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="login"/>
                <field name="shahtaj_employee_code"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
            </search>
        </field>
    </record>

    <record id="action_shahtaj_visit_hub" model="ir.actions.act_window">
        <field name="name">Visit Tasks</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('shahtaj_is_order_booker', '=', True)]</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="search_view_id" ref="view_shahtaj_visit_hub_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Select an order booker to review visit progress
            </p>
            <p>
                Each task is one scheduled shop visit. Track today's completions,
                this week's progress, and past history per booker.
            </p>
        </field>
    </record>

    <record id="action_shahtaj_visit_hub_view_list" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_shahtaj_visit_hub_list"/>
        <field name="act_window_id" ref="action_shahtaj_visit_hub"/>
    </record>

    <record id="action_shahtaj_visit_hub_view_form" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_shahtaj_visit_hub_form"/>
        <field name="act_window_id" ref="action_shahtaj_visit_hub"/>
    </record>

</odoo>
