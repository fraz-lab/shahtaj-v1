<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shahtaj_schedule_hub_list" model="ir.ui.view">
        <field name="name">res.users.list.shahtaj.schedule.hub</field>
        <field name="model">res.users</field>
        <field name="priority">40</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="login" optional="show"/>
                <field name="shahtaj_employee_code" optional="show"/>
                <field name="shahtaj_schedule_count" string="Schedule Lines"/>
                <field name="shahtaj_week_task_progress" string="Week %" widget="progressbar"/>
                <field name="shahtaj_week_task_done" string="Week Done"/>
                <field name="shahtaj_week_task_total" string="Week Total"/>
                <field name="shahtaj_task_today_done" string="Today Done"/>
                <field name="shahtaj_task_today_total" string="Today Total"/>
                <button name="action_shahtaj_manage_schedules" type="object"
                        string="Edit Routes" icon="fa-calendar" class="btn-link"/>
                <field name="active" widget="boolean_toggle" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_shahtaj_schedule_hub_form" model="ir.ui.view">
        <field name="name">res.users.form.shahtaj.schedule.hub</field>
        <field name="model">res.users</field>
        <field name="priority">40</field>
        <field name="arch" type="xml">
            <form string="Weekly Schedule" create="false" delete="false">
                <header>
                    <button name="action_shahtaj_manage_schedules" type="object"
                            string="Edit Weekly Routes" class="oe_highlight" icon="fa-calendar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                        <div class="text-muted">
                            <field name="login" readonly="1"/> —
                            <field name="shahtaj_employee_code" readonly="1"/>
                        </div>
                    </div>
                    <group string="This Week Overview">
                        <group>
                            <field name="shahtaj_week_task_progress" widget="progressbar" readonly="1"/>
                            <field name="shahtaj_week_task_done" readonly="1"/>
                            <field name="shahtaj_week_task_total" readonly="1"/>
                        </group>
                        <group>
                            <field name="shahtaj_task_today_done" readonly="1"/>
                            <field name="shahtaj_task_today_total" readonly="1"/>
                            <field name="shahtaj_schedule_count" readonly="1"/>
                        </group>
                    </group>
                    <group string="Current Route Plan (read-only summary)">
                        <p colspan="2" class="text-muted">
                            Click <b>Edit Weekly Routes</b> to add, change, or remove route assignments.
                            Today's weekday cannot be edited — other days can be changed freely.
                        </p>
                        <field name="shahtaj_schedule_ids" nolabel="1" colspan="2" readonly="1">
                            <list default_order="day_of_week,route_id">
                                <field name="day_of_week"/>
                                <field name="route_id"/>
                                <field name="zone_id"/>
                                <field name="shop_count"/>
                                <field name="week_occurrence_date" string="This Week"/>
                                <field name="week_tasks_completed" string="Done"/>
                                <field name="week_tasks_planned" string="Planned"/>
                                <field name="week_tasks_progress" widget="progressbar"/>
                                <field name="active"/>
                            </list>
                        </field>
                    </group>
                    <field name="shahtaj_is_order_booker" invisible="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_shahtaj_schedule_hub_search" model="ir.ui.view">
        <field name="name">res.users.search.shahtaj.schedule.hub</field>
        <field name="model">res.users</field>
        <field name="priority">40</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="login"/>
                <field name="shahtaj_employee_code"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
            </search>
        </field>
    </record>

    <record id="action_shahtaj_schedule_hub" model="ir.actions.act_window">
        <field name="name">Weekly Schedules</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('shahtaj_is_order_booker', '=', True)]</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="search_view_id" ref="view_shahtaj_schedule_hub_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Select an order booker to plan their week
            </p>
            <p>
                Click <b>Edit Routes</b> on a booker to assign routes per weekday.
                Visit tasks are created automatically when you save.
            </p>
        </field>
    </record>

    <record id="action_shahtaj_schedule_hub_view_list" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_shahtaj_schedule_hub_list"/>
        <field name="act_window_id" ref="action_shahtaj_schedule_hub"/>
    </record>

    <record id="action_shahtaj_schedule_hub_view_form" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_shahtaj_schedule_hub_form"/>
        <field name="act_window_id" ref="action_shahtaj_schedule_hub"/>
    </record>

    <!-- Order booker: read-only weekly schedule lines -->
    <record id="view_shahtaj_my_schedule_list" model="ir.ui.view">
        <field name="name">shahtaj.weekly.schedule.list.my</field>
        <field name="model">shahtaj.weekly.schedule</field>
        <field name="priority">10</field>
        <field name="arch" type="xml">
            <list create="false" edit="false" delete="false"
                  default_order="day_of_week,route_id">
                <field name="day_of_week"/>
                <field name="route_id"/>
                <field name="zone_id"/>
                <field name="shop_count"/>
                <field name="week_occurrence_date" string="This Week"/>
                <field name="week_tasks_completed" string="Done"/>
                <field name="week_tasks_planned" string="Planned"/>
                <field name="week_tasks_progress" widget="progressbar"/>
            </list>
        </field>
    </record>

    <record id="action_shahtaj_my_weekly_schedule" model="ir.actions.act_window">
        <field name="name">My Weekly Schedule</field>
        <field name="res_model">shahtaj.weekly.schedule</field>
        <field name="view_mode">list</field>
        <field name="domain">[('order_booker_id', '=', uid), ('active', '=', True)]</field>
        <field name="context">{'create': False, 'edit': False, 'delete': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No weekly schedule assigned yet
            </p>
            <p>Your distributor will assign routes for each weekday.</p>
        </field>
    </record>

    <record id="action_shahtaj_my_weekly_schedule_view_list" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_shahtaj_my_schedule_list"/>
        <field name="act_window_id" ref="action_shahtaj_my_weekly_schedule"/>
    </record>

</odoo>
