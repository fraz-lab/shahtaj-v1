<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shahtaj_visit_checkin_wizard_form" model="ir.ui.view">
        <field name="name">shahtaj.visit.checkin.wizard.form</field>
        <field name="model">shahtaj.visit.checkin.wizard</field>
        <field name="arch" type="xml">
            <form string="Check in at Shop">
                <group>
                    <field name="visit_task_id" invisible="1"/>
                    <field name="shop_id" readonly="1"/>
                    <field name="shop_latitude" readonly="1"/>
                    <field name="shop_longitude" readonly="1"/>
                </group>
                <group string="Your GPS Location">
                    <field name="booker_latitude" required="1"
                           placeholder="e.g. 31.5204"/>
                    <field name="booker_longitude" required="1"
                           placeholder="e.g. 74.3587"/>
                </group>
                <div class="alert alert-info" role="alert">
                    You must be within 100 m of the shop to start the visit timer.
                    For testing on desktop, copy the shop coordinates shown above.
                </div>
                <footer>
                    <button name="action_check_in" type="object" string="I'm at Shop"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
