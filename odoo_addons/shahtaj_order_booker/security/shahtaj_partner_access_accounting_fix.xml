<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Allow distributor to read company partner + shop invoice/delivery contacts (accounting). -->
    <data noupdate="0">
        <record id="rule_shahtaj_distributor_partner_read" model="ir.rule">
            <field name="domain_force">[
                '|', '|', '|', '|',
                ('is_shahtaj_shop', '=', True),
                ('partner_share', '=', False),
                ('id', '=', user.partner_id.id),
                ('id', '=', user.company_id.partner_id.id),
                ('commercial_partner_id.is_shahtaj_shop', '=', True),
            ]</field>
        </record>
    </data>
</odoo>
